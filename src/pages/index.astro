---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import Contact from '../components/Contact.astro';
---

<Layout 
  title="Peintre en Bâtiment à Toulon | Services de Peinture Professionnelle"
  description="Artisan peintre professionnel à Toulon. Peinture intérieure, extérieure et rénovation pour particuliers et professionnels. Devis gratuit."
>
  <main>
    <Hero 
      title="Peintre en Bâtiment"
      subtitle="Plus de 15 ans d'expérience à votre service"
    />
    <About />
    <Services />
    <Portfolio />
    <Contact />
  </main>

  <footer>
    <div class="container">
      <p class="footer-name">Baudy Peinture — Artisan Peintre à Toulon</p>
      <p class="footer-address">Toulon, Var (83) &nbsp;|&nbsp; <a href="tel:+33620156410">06 20 15 64 10</a> &nbsp;|&nbsp; <a href="mailto:contact@baudy-peinture.com">contact@baudy-peinture.com</a></p>
      <p class="footer-copy">&copy; 2024 Baudy Peinture. Tous droits réservés.</p>
    </div>
  </footer>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  footer {
    background: rgb(var(--primary));
    color: white;
    padding: 2rem 0;
    text-align: center;
  }
  .footer-name {
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }
  .footer-address {
    font-size: 0.95rem;
    opacity: 0.85;
    margin-bottom: 1rem;
  }
  .footer-address a {
    color: white;
    text-decoration: none;
  }
  .footer-address a:hover {
    text-decoration: underline;
  }
  .footer-copy {
    font-size: 0.85rem;
    opacity: 0.6;
  }
</style>