---
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/og-image.jpg' } = Astro.props;
const siteUrl = 'https://www.baudy-peinture.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Baudy Peinture" />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "PaintingContractor",
      "name": "Baudy Peinture",
      "url": "https://www.baudy-peinture.com",
      "telephone": "+33620156410",
      "email": "contact@baudy-peinture.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Toulon",
        "addressRegion": "Provence-Alpes-Côte d'Azur",
        "postalCode": "83000",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.1242,
        "longitude": 5.9280
      },
      "areaServed": [
        { "@type": "City", "name": "Toulon" },
        { "@type": "City", "name": "La Seyne-sur-Mer" },
        { "@type": "City", "name": "Six-Fours-les-Plages" },
        { "@type": "City", "name": "Hyères" },
        { "@type": "City", "name": "La Valette-du-Var" }
      ],
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "09:00",
          "closes": "12:00"
        }
      ],
      "priceRange": "€€",
      "description": "Artisan peintre professionnel à Toulon. Peinture intérieure, extérieure et rénovation pour particuliers et professionnels."
    }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <Navigation />
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --primary: 23, 37, 84;
    --accent: 79, 70, 229;
    --text: 51, 51, 51;
    --background: 249, 250, 251;
    --card-bg: 255, 255, 255;
    --gradient-start: 79, 70, 229;
    --gradient-end: 67, 56, 202;
  }
  html {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    background: rgb(var(--background));
    color: rgb(var(--text));
    scroll-behavior: smooth;
    scroll-padding-top: 80px;
  }
  body {
    margin: 0;
    padding: 0;
    line-height: 1.6;
  }
  h1, h2, h3, h4, h5, h6 {
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }
  .page-header {
    background: linear-gradient(
      to right,
      rgba(var(--gradient-start), 0.9),
      rgba(var(--gradient-end), 0.9)
    ),
    url('/header-bg.jpg') center/cover;
    color: white;
    padding: 8rem 1.5rem;
    text-align: center;
    margin-top: 70px;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .section {
    padding: 6rem 0;
  }
  .section-title {
    text-align: center;
    margin-bottom: 4rem;
    font-size: 2.5rem;
    font-weight: 700;
    color: rgb(var(--primary));
    position: relative;
  }
  .section-title::after {
    content: "";
    position: absolute;
    bottom: -1rem;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background: rgb(var(--accent));
    border-radius: 2px;
  }
  .card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 12px rgba(0, 0, 0, 0.1);
  }
  @media (max-width: 768px) {
    .page-header {
      padding: 6rem 1.5rem;
    }
    .section {
      padding: 4rem 0;
    }
    .section-title {
      font-size: 2rem;
    }
  }
</style>